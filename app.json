{
  "expo": {
    "name": "Omnikit",
    "slug": "Omnikit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Omnikit-logo.png",
    "scheme": "com.omnikit.app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uksman.Omnikit"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Omnikit-logo.png",
        "backgroundImage": "./assets/images/Omnikit-logo.png",
        "monochromeImage": "./assets/images/Omnikit-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.uksman.Omnikit",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "MEDIA_LIBRARY"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Omnikit-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Omnikit-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Omnikit to save QR codes to your gallery.",
          "savePhotosPermission": "Allow Omnikit to save QR codes to your gallery.",
          "isStandard": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5f5281d6-4282-46c3-9249-833ea86e1a0a"
      }
    },
    "owner": "uksman"
  }
}